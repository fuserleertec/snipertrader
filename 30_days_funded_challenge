<script>
// Theme toggle
const toggle = document.getElementById('themeToggle');
const html = document.documentElement;
const stored = localStorage.getItem('st-theme');
if (stored === 'light') html.classList.add('light');
toggle.addEventListener('click', () => {
  html.classList.toggle('light');
  localStorage.setItem('st-theme', html.classList.contains('light') ? 'light' : 'dark');
});

// Cursor and animations (same as before)
const cur=document.getElementById('cur'), ring=document.getElementById('cur-r'), mg=document.getElementById('mglow');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';mg.style.left=mx+'px';mg.style.top=my+'px';});
(function ar(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(ar)})();
document.querySelectorAll('.card,.sb,a,button').forEach(el=>{el.addEventListener('mouseenter',()=>{cur.style.width='20px';cur.style.height='20px';ring.style.width='54px';ring.style.height='54px'});el.addEventListener('mouseleave',()=>{cur.style.width='12px';cur.style.height='12px';ring.style.width='36px';ring.style.height='36px'})});

// Particles (simplified canvas)
const canvas=document.getElementById('pcanvas'), ctx=canvas.getContext('2d');
let W,H; function rsz(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight} rsz(); window.addEventListener('resize',rsz);
const PAL=[[0,230,160],[0,212,255],[255,196,68],[191,122,240]];
class P{constructor(){this.reset()} reset(){this.x=Math.random()*W;this.y=Math.random()*H;this.vx=(Math.random()-.5)*.35;this.vy=(Math.random()-.5)*.35-.08;this.r=Math.random()*1.5+.3;this.life=Math.random()*.6+.4;this.decay=Math.random()*.0025+.0008;this.col=PAL[Math.floor(Math.random()*4)];} step(){this.x+=this.vx;this.y+=this.vy;this.life-=this.decay;if(this.life<=0||this.y<-10)this.reset()} draw(){ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fillStyle=`rgba(${this.col},${this.life*.65})`;ctx.fill()}}
const pts=Array.from({length:200},()=>new P());
function conn(){for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<85){const a=(1-d/85)*.11*pts[i].life*pts[j].life;ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.strokeStyle=`rgba(0,230,160,${a})`;ctx.lineWidth=.4;ctx.stroke()}}}
function ap(){ctx.clearRect(0,0,W,H);pts.forEach(p=>{p.step();p.draw()});conn();requestAnimationFrame(ap)} ap();

// 3D tilt & reveal
document.querySelectorAll('.card').forEach(c=>{c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();const dx=(e.clientX-r.left-r.width/2)/(r.width/2);const dy=(e.clientY-r.top-r.height/2)/(r.height/2);c.style.transform=`perspective(900px) rotateX(${dy*-6}deg) rotateY(${dx*8}deg) scale(1.015)`;});c.addEventListener('mouseleave',()=>{c.style.transform=''});});
const io=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')})},{threshold:.07});
document.querySelectorAll('.section,.phase').forEach(el=>io.observe(el));
</script>
