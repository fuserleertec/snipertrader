<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Terms of Service — SniperTrader</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<style>
/* ============================================================
   CSS VARIABLES — SniperTrader Brand System
   ============================================================ */
:root {
  --obsidian:    #0a0b0e;
  --obsidian-2:  #0f1014;
  --obsidian-3:  #13151a;
  --obsidian-4:  #1a1d24;
  --cyan:        #00e5ff;
  --cyan-dim:    #00b8d4;
  --cyan-ghost:  rgba(0,229,255,0.08);
  --cyan-glow:   rgba(0,229,255,0.35);
  --gold:        #ffc107;
  --gold-dim:    #e6a800;
  --gold-ghost:  rgba(255,193,7,0.08);
  --gold-glow:   rgba(255,193,7,0.35);
  --red:         #ff3d5a;
  --red-ghost:   rgba(255,61,90,0.08);
  --white:       #f8fafc;
  --white-dim:   rgba(248,250,252,0.92);
  --white-muted: rgba(248,250,252,0.62);
  --glass-bg:    #12151c;
  --glass-border:rgba(0,229,255,0.14);
  --glass-hover: rgba(0,229,255,0.22);
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--obsidian);
  color: var(--white);
  font-family: 'Syne', sans-serif;
  font-size: 15px;
  line-height: 1.7;
  overflow-x: hidden;
  cursor: none;
}

/* ============================================================
   CUSTOM CURSOR
   ============================================================ */
.cursor-dot {
  position: fixed;
  width: 6px; height: 6px;
  background: var(--cyan);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%,-50%);
  transition: transform 0.05s, background 0.2s;
  box-shadow: 0 0 10px var(--cyan), 0 0 20px var(--cyan-glow);
}
.cursor-ring {
  position: fixed;
  width: 32px; height: 32px;
  border: 1px solid rgba(0,229,255,0.5);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%,-50%);
  transition: transform 0.12s cubic-bezier(0.23,1,0.32,1),
              width 0.2s, height 0.2s, border-color 0.2s;
}
.cursor-ring.hover {
  width: 48px; height: 48px;
  border-color: var(--gold);
}

/* ============================================================
   CANVAS — PARTICLE FIELD
   ============================================================ */
#particle-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.6;
}

/* ============================================================
   GRID OVERLAY
   ============================================================ */
.grid-overlay {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(0,229,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,229,255,0.025) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 100% 100% at 50% 0%, black 40%, transparent 100%);
}

/* ============================================================
   SCANLINES
   ============================================================ */
.scanlines {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0,0,0,0.03) 2px,
    rgba(0,0,0,0.03) 4px
  );
}

/* ============================================================
   NAV
   ============================================================ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 0 40px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(10,11,14,0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(0,229,255,0.1);
}

.nav-logo {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: 1.1rem;
  letter-spacing: 0.12em;
  text-decoration: none;
  background: linear-gradient(135deg, var(--cyan) 0%, var(--gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.nav-badge {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  color: var(--white-muted);
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

/* ============================================================
   HERO BANNER
   ============================================================ */
.hero {
  position: relative;
  z-index: 2;
  min-height: 340px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 130px 40px 60px;
  text-align: center;
  overflow: hidden;
}

/* Radial glow behind hero */
.hero::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-60%);
  width: 800px; height: 400px;
  background: radial-gradient(ellipse, rgba(0,229,255,0.08) 0%, transparent 70%);
  pointer-events: none;
}

.hero-eyebrow {
  font-family: 'Space Mono', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--cyan);
  margin-bottom: 16px;
  animation: fadeUp 0.8s ease both;
}

.hero-title {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  letter-spacing: 0.04em;
  line-height: 1.1;
  background: linear-gradient(135deg, #fff 30%, var(--cyan) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: fadeUp 0.8s 0.1s ease both;
}

.hero-sub {
  margin-top: 18px;
  font-family: 'Space Mono', monospace;
  font-size: 0.75rem;
  color: var(--white-muted);
  letter-spacing: 0.12em;
  animation: fadeUp 0.8s 0.2s ease both;
}

.hero-divider {
  margin-top: 40px;
  width: 100%;
  max-width: 960px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan-dim), transparent);
  animation: fadeUp 0.8s 0.3s ease both;
}

/* ============================================================
   LAYOUT
   ============================================================ */
.page-wrap {
  position: relative;
  z-index: 2;
  max-width: 960px;
  margin: 0 auto;
  padding: 0 40px 120px;
}

/* ============================================================
   QUICK NAV PILL
   ============================================================ */
.toc-pill {
  margin: 48px 0 60px;
  padding: 24px 28px;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: 14px;
  backdrop-filter: blur(12px);
  animation: fadeUp 0.8s 0.4s ease both;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.toc-pill:hover {
  border-color: var(--glass-hover);
  box-shadow: 0 0 32px rgba(0,229,255,0.06);
}

.toc-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--cyan);
  margin-bottom: 14px;
}

.toc-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 6px 16px;
}

.toc-grid a {
  font-family: 'Space Mono', monospace;
  font-size: 0.7rem;
  color: var(--white-dim);
  text-decoration: none;
  padding: 4px 0;
  letter-spacing: 0.05em;
  transition: color 0.2s;
  display: flex;
  align-items: center;
  gap: 8px;
}
.toc-grid a::before {
  content: '→';
  color: var(--cyan);
  font-size: 0.65rem;
  opacity: 0.6;
  transition: opacity 0.2s, transform 0.2s;
}
.toc-grid a:hover { color: var(--cyan); }
.toc-grid a:hover::before { opacity: 1; transform: translateX(3px); }

/* ============================================================
   SECTION CARDS — 3D TILT
   ============================================================ */
.section-card {
  position: relative;
  margin-bottom: 28px;
  padding: 36px 40px;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: 16px;
  backdrop-filter: blur(16px);
  transform-style: preserve-3d;
  transition: border-color 0.3s, box-shadow 0.3s;
  animation: fadeUp 0.6s ease both;
  will-change: transform;
  overflow: hidden;
}

.section-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: radial-gradient(
    600px circle at var(--mx, 50%) var(--my, 50%),
    rgba(0,229,255,0.04),
    transparent 60%
  );
  pointer-events: none;
  transition: opacity 0.3s;
  opacity: 0;
}
.section-card:hover::before { opacity: 1; }

.section-card:hover {
  border-color: var(--glass-hover);
  box-shadow: 0 8px 48px rgba(0,229,255,0.08), 0 2px 0 inset rgba(0,229,255,0.06);
}

/* accent bar left edge */
.section-card::after {
  content: '';
  position: absolute;
  left: 0; top: 20%; bottom: 20%;
  width: 2px;
  border-radius: 2px;
  background: linear-gradient(180deg, transparent, var(--cyan), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}
.section-card:hover::after { opacity: 1; }

/* Section number */
.section-num {
  position: absolute;
  top: 22px; right: 28px;
  font-family: 'Orbitron', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  color: rgba(0,229,255,0.2);
  letter-spacing: 0.2em;
}

.section-card h2 {
  font-family: 'Orbitron', sans-serif;
  font-weight: 700;
  font-size: 0.95rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--cyan);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.section-card h2 .icon {
  width: 28px; height: 28px;
  border-radius: 6px;
  background: var(--cyan-ghost);
  border: 1px solid rgba(0,229,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  flex-shrink: 0;
}

.section-card p {
  color: var(--white-dim);
  font-size: 0.88rem;
  line-height: 1.8;
  margin-bottom: 12px;
}
.section-card p:last-child { margin-bottom: 0; }

.section-card ul {
  list-style: none;
  margin: 12px 0;
}
.section-card ul li {
  position: relative;
  padding-left: 20px;
  color: var(--white-dim);
  font-size: 0.88rem;
  line-height: 1.8;
  margin-bottom: 4px;
}
.section-card ul li::before {
  content: '▸';
  position: absolute;
  left: 0;
  color: var(--cyan);
  font-size: 0.65rem;
  top: 5px;
}

strong {
  color: var(--white);
  font-weight: 600;
}

.highlight-gold { color: var(--gold); font-weight: 600; }
.highlight-red   { color: var(--red);  font-weight: 600; }
.highlight-cyan  { color: var(--cyan); font-weight: 600; }

/* ============================================================
   WARNING CARD
   ============================================================ */
.warning-card {
  border-color: rgba(255,193,7,0.25);
  background: #141209;
}
.warning-card::after {
  background: linear-gradient(180deg, transparent, var(--gold), transparent);
}
.warning-card:hover {
  border-color: rgba(255,193,7,0.45);
  box-shadow: 0 8px 48px rgba(255,193,7,0.06);
}
.warning-card::before {
  background: radial-gradient(
    600px circle at var(--mx,50%) var(--my,50%),
    rgba(255,193,7,0.04),
    transparent 60%
  );
}
.warning-card h2 { color: var(--gold); }
.warning-card h2 .icon {
  background: var(--gold-ghost);
  border-color: rgba(255,193,7,0.25);
}

/* ============================================================
   DANGER CARD
   ============================================================ */
.danger-card {
  border-color: rgba(255,61,90,0.25);
  background: #130a0c;
}
.danger-card::after {
  background: linear-gradient(180deg, transparent, var(--red), transparent);
}
.danger-card:hover {
  border-color: rgba(255,61,90,0.45);
  box-shadow: 0 8px 48px rgba(255,61,90,0.06);
}
.danger-card::before {
  background: radial-gradient(
    600px circle at var(--mx,50%) var(--my,50%),
    rgba(255,61,90,0.04),
    transparent 60%
  );
}
.danger-card h2 { color: var(--red); }
.danger-card h2 .icon {
  background: var(--red-ghost);
  border-color: rgba(255,61,90,0.25);
}

/* ============================================================
   INLINE CODE
   ============================================================ */
code {
  font-family: 'Space Mono', monospace;
  font-size: 0.75rem;
  background: rgba(0,229,255,0.07);
  border: 1px solid rgba(0,229,255,0.15);
  padding: 2px 7px;
  border-radius: 4px;
  color: var(--cyan);
}

/* ============================================================
   EFFECTIVE DATE BANNER
   ============================================================ */
.effective-banner {
  margin: 0 0 40px;
  padding: 14px 24px;
  background: rgba(0,229,255,0.04);
  border: 1px solid rgba(0,229,255,0.1);
  border-radius: 8px;
  display: flex;
  align-items: center;
  gap: 14px;
  font-family: 'Space Mono', monospace;
  font-size: 0.68rem;
  color: var(--white-muted);
  letter-spacing: 0.1em;
  animation: fadeUp 0.8s 0.35s ease both;
}
.effective-banner .dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--cyan);
  box-shadow: 0 0 10px var(--cyan);
  flex-shrink: 0;
  animation: pulse 2s ease infinite;
}

/* ============================================================
   FOOTER
   ============================================================ */
footer {
  position: relative;
  z-index: 2;
  border-top: 1px solid rgba(0,229,255,0.08);
  padding: 40px;
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  justify-content: space-between;
}
.footer-brand {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: 0.85rem;
  letter-spacing: 0.15em;
  background: linear-gradient(135deg, var(--cyan), var(--gold));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.footer-copy {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  color: var(--white-muted);
  letter-spacing: 0.1em;
}
.footer-links {
  display: flex;
  gap: 24px;
}
.footer-links a {
  font-family: 'Space Mono', monospace;
  font-size: 0.62rem;
  color: var(--white-muted);
  text-decoration: none;
  letter-spacing: 0.08em;
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--cyan); }

/* ============================================================
   SCROLL PROGRESS
   ============================================================ */
.scroll-progress {
  position: fixed;
  top: 0; left: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--cyan), var(--gold));
  z-index: 200;
  transform-origin: left;
  box-shadow: 0 0 10px var(--cyan-glow);
  transition: width 0.1s linear;
}

/* ============================================================
   BACK TO TOP
   ============================================================ */
.back-top {
  position: fixed;
  bottom: 32px; right: 32px;
  z-index: 50;
  width: 44px; height: 44px;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: none;
  font-size: 0.85rem;
  color: var(--cyan);
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.3s, transform 0.3s, border-color 0.2s, box-shadow 0.2s;
  text-decoration: none;
}
.back-top.visible {
  opacity: 1;
  transform: translateY(0);
}
.back-top:hover {
  border-color: var(--cyan);
  box-shadow: 0 0 20px var(--cyan-glow);
}

/* ============================================================
   KEYFRAMES
   ============================================================ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.5; transform: scale(1.4); }
}

@keyframes glow-line {
  0%, 100% { opacity: 0.4; }
  50%       { opacity: 1; }
}

/* stagger section cards */
.section-card:nth-child(1)  { animation-delay: 0.05s; }
.section-card:nth-child(2)  { animation-delay: 0.10s; }
.section-card:nth-child(3)  { animation-delay: 0.15s; }
.section-card:nth-child(4)  { animation-delay: 0.20s; }
.section-card:nth-child(5)  { animation-delay: 0.25s; }
.section-card:nth-child(6)  { animation-delay: 0.30s; }
.section-card:nth-child(7)  { animation-delay: 0.35s; }
.section-card:nth-child(8)  { animation-delay: 0.40s; }
.section-card:nth-child(9)  { animation-delay: 0.45s; }
.section-card:nth-child(10) { animation-delay: 0.50s; }
.section-card:nth-child(11) { animation-delay: 0.55s; }
.section-card:nth-child(12) { animation-delay: 0.60s; }
.section-card:nth-child(13) { animation-delay: 0.65s; }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 640px) {
  nav { padding: 0 20px; }
  .hero { padding: 110px 20px 50px; }
  .page-wrap { padding: 0 20px 80px; }
  .section-card { padding: 28px 24px; }
  .toc-grid { grid-template-columns: 1fr 1fr; }
  footer { padding: 28px 20px; flex-direction: column; align-items: flex-start; }
}

/* ============================================================
   LIGHT MODE
   ============================================================ */
body.light-mode {
  --obsidian:    #f0f4f8;
  --obsidian-2:  #e8ecf0;
  --obsidian-3:  #dde2e8;
  --obsidian-4:  #cdd3db;
  --glass-bg:    #ffffff;
  --glass-border:rgba(0,180,210,0.25);
  --glass-hover: rgba(0,180,210,0.40);
  --white:       #0d1117;
  --white-dim:   rgba(13,17,23,0.88);
  --white-muted: rgba(13,17,23,0.55);
  background: var(--obsidian);
  color: var(--white);
}
body.light-mode nav {
  background: rgba(240,244,248,0.92);
  border-bottom-color: rgba(0,180,210,0.18);
}
body.light-mode footer {
  border-top-color: rgba(0,180,210,0.15);
}
body.light-mode .section-card {
  background: #ffffff;
  box-shadow: 0 2px 16px rgba(0,0,0,0.07);
}
body.light-mode .warning-card {
  background: #fffbee;
}
body.light-mode .danger-card {
  background: #fff5f7;
}
body.light-mode .toc-pill {
  background: #ffffff;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
body.light-mode .effective-banner {
  background: rgba(0,180,210,0.07);
}
body.light-mode .grid-overlay {
  background-image:
    linear-gradient(rgba(0,150,180,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,150,180,0.06) 1px, transparent 1px);
}
body.light-mode .back-top {
  background: #ffffff;
  border-color: rgba(0,180,210,0.3);
}
body.light-mode strong {
  color: #0d1117;
}

/* ── Theme Toggle Button ── */
.theme-toggle {
  width: 40px; height: 22px;
  border-radius: 11px;
  border: 1px solid var(--glass-border);
  background: var(--glass-bg);
  cursor: none;
  position: relative;
  flex-shrink: 0;
  transition: background 0.3s, border-color 0.3s;
  outline: none;
  display: flex;
  align-items: center;
  padding: 2px;
}
.theme-toggle::after {
  content: '';
  width: 16px; height: 16px;
  border-radius: 50%;
  background: var(--cyan);
  box-shadow: 0 0 8px var(--cyan-glow);
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), background 0.3s;
  flex-shrink: 0;
}
body.light-mode .theme-toggle::after {
  transform: translateX(18px);
  background: var(--gold);
  box-shadow: 0 0 8px var(--gold-glow);
}
body.light-mode .theme-toggle {
  background: rgba(255,193,7,0.08);
  border-color: rgba(255,193,7,0.3);
}
.theme-toggle-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
}
.theme-toggle-label {
  font-family: 'Space Mono', monospace;
  font-size: 0.58rem;
  letter-spacing: 0.15em;
  color: var(--white-muted);
  text-transform: uppercase;
  user-select: none;
  transition: color 0.3s;
}
</style>
</head>
<body>

<!-- Cursor -->
<div class="cursor-dot" id="cursorDot"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- Particle canvas -->
<canvas id="particle-canvas"></canvas>

<!-- Grid + Scanlines -->
<div class="grid-overlay"></div>
<div class="scanlines"></div>

<!-- Scroll progress bar -->
<div class="scroll-progress" id="scrollBar"></div>

<!-- Back to top -->
<a href="#top" class="back-top" id="backTop">↑</a>

<!-- ============================================================
     NAVIGATION
     ============================================================ -->
<nav id="top">
  <a href="index.html" class="nav-logo">SNIPERTRADER</a>
  <div style="display:flex;align-items:center;gap:16px;">
    <span class="nav-badge">LEGAL // TERMS OF SERVICE</span>
    <div class="theme-toggle-wrap">
      <span class="theme-toggle-label" id="themeLabel">DARK</span>
      <button class="theme-toggle" id="themeToggle" aria-label="Toggle light/dark mode"></button>
    </div>
  </div>
</nav>

<!-- ============================================================
