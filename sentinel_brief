<script>
// ── THEME TOGGLE
function toggleTheme(){
  const isLight = document.body.classList.toggle('light-mode');
  const btn = document.getElementById('themeToggle');
  btn.textContent = isLight ? '◐' : '◑';
  btn.title = isLight ? 'Switch to dark mode' : 'Switch to light mode';
  localStorage.setItem('sentinelTheme', isLight ? 'light' : 'dark');
}
// Restore saved preference
(function(){
  const saved = localStorage.getItem('sentinelTheme');
  if(saved === 'light'){
    document.body.classList.add('light-mode');
    const btn = document.getElementById('themeToggle');
    if(btn){ btn.textContent = '◐'; btn.title = 'Switch to dark mode'; }
  }
})();

// ── CURSOR
const ring=document.getElementById('cring'),dot=document.getElementById('cdot');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
(function ac(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';dot.style.left=mx+'px';dot.style.top=my+'px';requestAnimationFrame(ac);})();

// ── PARTICLES
const pc=document.getElementById('pcanvas'),pctx=pc.getContext('2d');
function rz(){pc.width=window.innerWidth;pc.height=window.innerHeight;}rz();
window.addEventListener('resize',rz);
class P{constructor(){this.reset();}reset(){this.x=Math.random()*pc.width;this.y=Math.random()*pc.height;this.vx=(Math.random()-.5)*.3;this.vy=(Math.random()-.5)*.3;this.life=Math.random();this.ml=.4+Math.random()*.6;this.r=Math.random()*1.2+.3;this.g=Math.random()>.88;}update(){this.x+=this.vx;this.y+=this.vy;this.life-=.001;if(this.life<=0)this.reset();if(this.x<0||this.x>pc.width)this.vx*=-1;if(this.y<0||this.y>pc.height)this.vy*=-1;}draw(){const a=Math.min(this.life/this.ml,1)*(this.g?.4:.25);pctx.beginPath();pctx.arc(this.x,this.y,this.r,0,Math.PI*2);pctx.fillStyle=this.g?`rgba(240,180,41,${a})`:`rgba(0,229,255,${a})`;pctx.fill();}}
const ps=Array.from({length:120},()=>new P());
function ap(){pctx.clearRect(0,0,pc.width,pc.height);ps.forEach(p=>{p.update();p.draw();});requestAnimationFrame(ap);}ap();

// ── SIDE ANCHORS
const secs=['sec-cover','sec-mission','sec-tiers','sec-commission','sec-playbook','sec-compliance','sec-payout','sec-tools','sec-faq'];
const anchors=document.getElementById('sideAnchors');
secs.forEach((id,i)=>{
  const btn=document.createElement('button');
  btn.className='anchor-pip';btn.title='Section '+(i+1);
  btn.onclick=()=>document.getElementById(id).scrollIntoView({behavior:'smooth'});
  anchors.appendChild(btn);
});
function updateAnchors(){
  secs.forEach((id,i)=>{
    const el=document.getElementById(id);
    if(!el)return;
    const rect=el.getBoundingClientRect();
    anchors.children[i].classList.toggle('active',rect.top<=200&&rect.bottom>200);
  });
}
window.addEventListener('scroll',updateAnchors);updateAnchors();

// ── SCROLL REVEALS
const reveals=document.querySelectorAll('.reveal');
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in');});
},{threshold:.08});
reveals.forEach(r=>io.observe(r));

// ── FAQ
function toggleFaq(q){
  const item=q.parentElement;
  const wasOpen=item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i=>i.classList.remove('open'));
  if(!wasOpen)item.classList.add('open');
}

