<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sentinel Program Brief — snipertrader.ai Intelligence Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --obsidian:  #070a0f;
  --obs2:      #0c1018;
  --obs3:      #111620;
  --obs4:      #161d2b;
  --cyan:      #00e5ff;
  --cyan-dim:  #00b8cc;
  --cyan-glow: rgba(0,229,255,.16);
  --gold:      #f0b429;
  --gold-glow: rgba(240,180,41,.18);
  --silver:    #c8d8ee;
  --white:     #f0f6ff;
  --muted:     #7a99bc;
  --muted2:    #9ab4d0;
  --glass:     #0d141f;
  --gborder:   rgba(0,229,255,.12);
  --ok:        #00e5a0;
  --warn:      #f0b429;
  --fdisplay:  'Orbitron', monospace;
  --fmono:     'Space Mono', monospace;
  --fbody:     'Syne', sans-serif;
}

/* ── LIGHT MODE */
body.light-mode {
  --obsidian:  #f0f4f8;
  --obs2:      #e4eaf2;
  --obs3:      #d8e0ec;
  --obs4:      #ccd6e8;
  --cyan:      #0077aa;
  --cyan-dim:  #005f88;
  --cyan-glow: rgba(0,119,170,.16);
  --gold:      #b07800;
  --gold-glow: rgba(176,120,0,.18);
  --silver:    #2a3a4a;
  --white:     #0a1520;
  --muted:     #4a6070;
  --muted2:    #2a3a4a;
  --glass:     #e8eef6;
  --gborder:   rgba(0,119,170,.15);
  --ok:        #007a44;
  --warn:      #b07800;
  background:var(--obsidian);
  color:var(--white);
}
body.light-mode #pcanvas { opacity: .15; }
body.light-mode .classified-banner {
  background: repeating-linear-gradient(-45deg,rgba(176,120,0,.06) 0,rgba(176,120,0,.06) 12px,transparent 12px,transparent 24px);
}
body.light-mode nav { background: rgba(240,244,248,.95); }
body.light-mode .cover { background: radial-gradient(ellipse 900px 500px at center,rgba(0,119,170,.07) 0%,transparent 65%); }
body.light-mode .comp-badge.prohibited { color: #cc2040; border-color: rgba(204,32,64,.3); }
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{
  background:var(--obsidian);color:var(--white);
  font-family:var(--fbody);overflow-x:hidden;cursor:none;
}

/* ── GRID OVERLAY */
body::before{
  content:'';position:fixed;inset:0;z-index:1;pointer-events:none;
  background-image:
    linear-gradient(rgba(0,229,255,.014) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,229,255,.014) 1px,transparent 1px);
  background-size:80px 80px;
}

/* ── CURSOR */
#cring{position:fixed;top:0;left:0;width:28px;height:28px;border:1.5px solid var(--cyan);border-radius:50%;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);mix-blend-mode:screen;}
#cdot{position:fixed;top:0;left:0;width:4px;height:4px;background:var(--cyan);border-radius:50%;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);}

/* ── PARTICLE BG */
#pcanvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:.4;}

/* ── NAV */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 40px;height:64px;
  background:rgba(7,10,15,.92);
  border-bottom:1px solid rgba(0,229,255,.08);
  backdrop-filter:blur(20px);
}
.nav-logo{font-family:var(--fdisplay);font-size:13px;font-weight:700;letter-spacing:.18em;color:var(--white);text-decoration:none;display:flex;align-items:center;gap:10px;}
.nav-logo span{color:var(--cyan);}
.nav-logo::before{content:'⊕';font-size:16px;color:var(--cyan);text-shadow:0 0 12px var(--cyan);}
.nav-links{display:flex;gap:36px;list-style:none;}
.nav-links a{font-family:var(--fmono);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--silver);text-decoration:none;transition:color .2s;}
.nav-links a:hover{color:var(--cyan);}
.nav-back{font-family:var(--fdisplay);font-size:9px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;padding:9px 20px;border:1px solid rgba(0,229,255,.18);color:var(--silver);background:transparent;text-decoration:none;transition:border-color .2s,color .2s;}
.nav-back:hover{border-color:var(--cyan);color:var(--cyan);}
.theme-toggle{
  font-size:16px;background:transparent;border:1px solid rgba(0,229,255,.18);
  color:var(--silver);cursor:pointer;padding:7px 12px;margin-left:12px;
  transition:border-color .2s,color .2s,transform .3s;line-height:1;
}
.theme-toggle:hover{border-color:var(--cyan);color:var(--cyan);}
body.light-mode .theme-toggle{border-color:rgba(0,119,170,.3);}

/* ── LAYOUT */
.page{position:relative;z-index:10;padding-top:64px;}

/* ── CLASSIFIED BANNER */
.classified-banner{
  background:repeating-linear-gradient(
    -45deg,
    rgba(240,180,41,.06) 0,rgba(240,180,41,.06) 12px,
    transparent 12px,transparent 24px
  );
  border-top:1px solid rgba(240,180,41,.2);
  border-bottom:1px solid rgba(240,180,41,.2);
  padding:10px 40px;
  display:flex;align-items:center;justify-content:center;gap:32px;
}
.classified-text{
  font-family:var(--fmono);font-size:9px;letter-spacing:.4em;
  text-transform:uppercase;color:var(--gold);
  display:flex;align-items:center;gap:12px;
}
.classified-text::before,.classified-text::after{content:'◈';color:var(--gold);opacity:.6;}

/* ── COVER */
.cover{
  min-height:90vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;padding:80px 40px 60px;
  position:relative;overflow:hidden;
  background:radial-gradient(ellipse 900px 500px at center,rgba(0,229,255,.05) 0%,transparent 65%);
}
.cover-meta{
  font-family:var(--fmono);font-size:8px;letter-spacing:.3em;
  color:var(--muted);text-transform:uppercase;margin-bottom:40px;
  border:1px solid rgba(0,229,255,.08);padding:10px 24px;
  display:inline-flex;gap:32px;
}
.cover-meta span{color:var(--muted2);}
.cover-seal{
  width:80px;height:80px;border-radius:50%;
  border:1px solid rgba(0,229,255,.2);
  display:flex;align-items:center;justify-content:center;
  font-size:32px;margin:0 auto 32px;
  background:rgba(0,229,255,.03);
  box-shadow:0 0 40px rgba(0,229,255,.1),inset 0 0 20px rgba(0,229,255,.04);
  animation:sealPulse 3s ease-in-out infinite;
}
@keyframes sealPulse{0%,100%{box-shadow:0 0 40px rgba(0,229,255,.1),inset 0 0 20px rgba(0,229,255,.04)}50%{box-shadow:0 0 80px rgba(0,229,255,.2),inset 0 0 30px rgba(0,229,255,.08)}}
.cover-eyebrow{
  font-family:var(--fmono);font-size:9px;letter-spacing:.4em;
  color:var(--cyan);text-transform:uppercase;margin-bottom:20px;
  opacity:.7;
}
.cover-title{
  font-family:var(--fdisplay);font-size:clamp(36px,6vw,72px);
  font-weight:900;letter-spacing:.05em;text-transform:uppercase;
  line-height:1.0;margin-bottom:10px;
}
.cover-title .t1{color:var(--white);}
.cover-title .t2{color:var(--cyan);text-shadow:0 0 40px rgba(0,229,255,.4),0 0 80px rgba(0,229,255,.15);}
.cover-sub{
  font-family:var(--fmono);font-size:10px;letter-spacing:.25em;
  color:var(--muted2);text-transform:uppercase;margin-bottom:48px;
}
.cover-desc{
  font-size:16px;line-height:1.8;color:var(--muted2);
  max-width:600px;margin:0 auto 56px;
}
.cover-desc em{color:var(--cyan);font-style:normal;font-weight:600;}

/* ── TOC */
.toc-block{
  border:1px solid rgba(0,229,255,.1);
  background:rgba(0,229,255,.02);
  padding:40px 48px;max-width:600px;margin:0 auto;
  text-align:left;
}
.toc-title{
  font-family:var(--fdisplay);font-size:9px;font-weight:700;
  letter-spacing:.3em;text-transform:uppercase;
  color:var(--cyan);margin-bottom:24px;opacity:.7;
}
.toc-list{list-style:none;display:flex;flex-direction:column;gap:0;}
.toc-list li{
  display:flex;align-items:center;gap:16px;
  padding:10px 0;border-bottom:1px solid rgba(0,229,255,.05);
  cursor:pointer;transition:all .2s;
}
.toc-list li:last-child{border-bottom:none;}
.toc-list li:hover .toc-link{color:var(--cyan);}
.toc-list li:hover .toc-num{opacity:1;}
.toc-num{
  font-family:var(--fdisplay);font-size:9px;font-weight:700;
  letter-spacing:.2em;color:var(--cyan);opacity:.35;
  width:28px;flex-shrink:0;transition:opacity .2s;
}
.toc-link{
  font-family:var(--fmono);font-size:11px;letter-spacing:.1em;
  color:var(--muted2);text-decoration:none;
  transition:color .2s;flex:1;
}
.toc-dot{
  width:4px;height:4px;border-radius:50%;
  background:var(--muted);opacity:.3;flex-shrink:0;
}

/* ── DIVIDER */
.divider{width:100%;height:1px;background:linear-gradient(to right,transparent,rgba(0,229,255,.15),transparent);}

/* ── SECTION */
.section{
  max-width:1100px;margin:0 auto;
  padding:100px 48px;
}
.section-header{margin-bottom:64px;}
.section-code{
  font-family:var(--fmono);font-size:8px;letter-spacing:.35em;
  color:var(--cyan);text-transform:uppercase;opacity:.55;
  margin-bottom:12px;display:flex;align-items:center;gap:10px;
}
.section-code::before{content:'//';}
.section-title{
  font-family:var(--fdisplay);font-size:clamp(24px,3.5vw,42px);
  font-weight:900;letter-spacing:.05em;text-transform:uppercase;
  color:var(--white);line-height:1.0;margin-bottom:16px;
}
.section-title span{color:var(--cyan);}
.section-lead{
  font-size:15px;line-height:1.8;color:var(--muted2);
  max-width:680px;
}
.section-lead em{color:var(--white);font-style:normal;font-weight:600;}

/* ── PROSE */
.prose{
  font-size:14px;line-height:1.9;color:var(--muted2);
  max-width:760px;
}
.prose p{margin-bottom:20px;}
.prose p:last-child{margin-bottom:0;}
.prose em{color:var(--white);font-style:normal;font-weight:600;}
.prose strong{color:var(--cyan);}
.prose a{color:var(--cyan);text-decoration:none;border-bottom:1px solid rgba(0,229,255,.2);}

/* ── CALLOUT */
.callout{
  border-left:2px solid var(--cyan);
  background:rgba(0,229,255,.03);
  padding:20px 24px;margin:28px 0;
  font-size:14px;line-height:1.7;color:var(--silver);
}
.callout.gold{border-left-color:var(--gold);background:rgba(240,180,41,.03);}
.callout-label{
  font-family:var(--fmono);font-size:8px;letter-spacing:.25em;
  text-transform:uppercase;color:var(--cyan);margin-bottom:8px;
  display:flex;align-items:center;gap:8px;
}
.callout.gold .callout-label{color:var(--gold);}

/* ── INFO GRID */
.info-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:2px;
  margin-top:40px;
}
.info-cell{
  background:var(--glass);
  border:1px solid rgba(0,229,255,.07);
  padding:32px 36px;
  transition:border-color .25s;
  position:relative;overflow:hidden;
}
.info-cell::after{
  content:'';position:absolute;bottom:0;left:0;right:0;
  height:1px;background:linear-gradient(to right,var(--cyan),transparent);
  transform:scaleX(0);transform-origin:left;
  transition:transform .3s;
}
.info-cell:hover{border-color:rgba(0,229,255,.2);}
.info-cell:hover::after{transform:scaleX(1);}
.info-cell-icon{font-size:22px;margin-bottom:16px;display:block;}
.info-cell h4{
  font-family:var(--fdisplay);font-size:11px;font-weight:700;
  letter-spacing:.15em;text-transform:uppercase;
  color:var(--white);margin-bottom:10px;
}
.info-cell p{font-size:13px;line-height:1.7;color:var(--muted2);}
.info-cell p strong{color:var(--cyan);}

/* ── TIER TABLE */
.tier-table{width:100%;border-collapse:collapse;margin-top:40px;}
.tier-table thead tr{border-bottom:1px solid rgba(0,229,255,.15);}
.tier-table th{
  font-family:var(--fmono);font-size:8px;letter-spacing:.25em;
  text-transform:uppercase;color:var(--cyan);opacity:.6;
  padding:12px 20px;text-align:left;font-weight:400;
}
.tier-table tbody tr{
  border-bottom:1px solid rgba(0,229,255,.05);
  transition:background .2s;
}
.tier-table tbody tr:hover{background:rgba(0,229,255,.025);}
.tier-table td{
  padding:20px;font-size:13px;color:var(--muted2);
  vertical-align:top;
}
.tier-table td:first-child{width:100px;}
.tier-name-tag{
  font-family:var(--fdisplay);font-size:10px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  padding:5px 12px;display:inline-block;
  border:1px solid;
}
.tier-name-tag.r{color:#3a5070;border-color:#1a2a3a;}
.tier-name-tag.o{color:var(--silver);border-color:rgba(143,163,192,.3);}
.tier-name-tag.c{color:var(--cyan);border-color:rgba(0,229,255,.3);background:rgba(0,229,255,.04);}
.tier-name-tag.g{color:var(--gold);border-color:rgba(240,180,41,.35);background:rgba(240,180,41,.04);}
.tier-pct{
  font-family:var(--fdisplay);font-size:15px;font-weight:900;
  color:var(--white);white-space:nowrap;
}
.tier-table td.cyan .tier-pct{color:var(--cyan);}
.tier-table td.gold-c .tier-pct{color:var(--gold);}

/* ── COMMISSION BREAKDOWN */
.commission-stack{
  display:flex;flex-direction:column;gap:2px;margin-top:40px;
}
.com-row{
  display:grid;grid-template-columns:220px 1fr auto;
  align-items:center;gap:0;
  background:var(--glass);
  border:1px solid rgba(0,229,255,.07);
  padding:22px 28px;
  transition:border-color .2s;
}
.com-row:hover{border-color:rgba(0,229,255,.18);}
.com-label{
  font-family:var(--fdisplay);font-size:10px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;color:var(--white);
}
.com-desc{font-size:12px;color:var(--muted2);line-height:1.5;padding:0 24px;}
.com-value{
  font-family:var(--fdisplay);font-size:18px;font-weight:900;
  color:var(--cyan);text-align:right;white-space:nowrap;
}
.com-value.gold-v{color:var(--gold);}
.com-value.silver-v{color:var(--silver);}
.com-value.muted-v{color:var(--muted2);}

/* ── CONTENT PLAYBOOK */
.playbook-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:2px;
  margin-top:40px;
}
.playbook-card{
  background:var(--glass);border:1px solid rgba(0,229,255,.07);
  padding:36px 28px;
  transition:border-color .25s,transform .25s;
  position:relative;overflow:hidden;
}
.playbook-card::before{
  content:'';position:absolute;top:0;left:0;right:0;
  height:2px;background:transparent;transition:background .3s;
}
.playbook-card:hover{border-color:rgba(0,229,255,.22);transform:translateY(-3px);}
.playbook-card:hover::before{background:linear-gradient(to right,var(--cyan),transparent);}
.playbook-tag{
  font-family:var(--fmono);font-size:8px;letter-spacing:.25em;
  text-transform:uppercase;color:var(--cyan);opacity:.55;
  margin-bottom:14px;
}
.playbook-card h4{
  font-family:var(--fdisplay);font-size:12px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  color:var(--white);margin-bottom:14px;
}
.playbook-card ul{
  list-style:none;display:flex;flex-direction:column;gap:10px;
}
.playbook-card li{
  font-size:12px;color:var(--muted2);line-height:1.5;
  padding-left:14px;position:relative;
}
.playbook-card li::before{content:'›';position:absolute;left:0;color:var(--cyan);opacity:.5;}
.playbook-card li strong{color:var(--silver);}

/* ── COMPLIANCE TABLE */
.compliance-block{
  display:flex;flex-direction:column;gap:2px;margin-top:40px;
}
.comp-row{
  display:grid;grid-template-columns:28px 1fr auto;
  align-items:flex-start;gap:20px;
  padding:20px 24px;
  background:var(--glass);border:1px solid rgba(0,229,255,.07);
}
.comp-icon{
  font-size:14px;padding-top:2px;flex-shrink:0;
}
.comp-text{font-size:13px;color:var(--muted2);line-height:1.6;}
.comp-text strong{color:var(--white);}
.comp-badge{
  font-family:var(--fmono);font-size:8px;letter-spacing:.15em;
  text-transform:uppercase;padding:5px 10px;flex-shrink:0;
  border:1px solid;white-space:nowrap;
}
.comp-badge.required{color:var(--cyan);border-color:rgba(0,229,255,.25);}
.comp-badge.prohibited{color:#ff4060;border-color:rgba(255,64,96,.25);}
.comp-badge.best{color:var(--ok);border-color:rgba(0,229,160,.25);}

/* ── PAYOUT TIMELINE */
.payout-track{
  display:grid;grid-template-columns:repeat(4,1fr);gap:2px;
  margin-top:40px;position:relative;
}
.payout-track::before{
  content:'';position:absolute;top:32px;left:10%;right:10%;
  height:1px;background:linear-gradient(to right,var(--cyan),rgba(0,229,255,.2));
  z-index:0;
}
.payout-node{
  background:var(--glass);border:1px solid rgba(0,229,255,.08);
  padding:28px 24px;position:relative;z-index:1;
  text-align:center;transition:border-color .2s;
}
.payout-node:hover{border-color:rgba(0,229,255,.25);}
.payout-circle{
  width:32px;height:32px;border-radius:50%;
  border:1px solid var(--cyan);background:rgba(0,229,255,.07);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 16px;
  font-family:var(--fdisplay);font-size:9px;font-weight:700;
  color:var(--cyan);
}
.payout-month{
  font-family:var(--fdisplay);font-size:10px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  color:var(--white);margin-bottom:8px;
}
.payout-desc{font-size:11px;color:var(--muted2);line-height:1.5;}

/* ── TOOLS LIST */
.tools-list{
  display:grid;grid-template-columns:1fr 1fr;gap:2px;
  margin-top:40px;
}
.tool-item{
  display:flex;align-items:flex-start;gap:16px;
  background:var(--glass);border:1px solid rgba(0,229,255,.07);
  padding:24px 28px;transition:border-color .2s;
}
.tool-item:hover{border-color:rgba(0,229,255,.2);}
.tool-icon{font-size:20px;flex-shrink:0;padding-top:2px;}
.tool-info h5{
  font-family:var(--fdisplay);font-size:10px;font-weight:700;
  letter-spacing:.15em;text-transform:uppercase;
  color:var(--white);margin-bottom:6px;
}
.tool-info p{font-size:12px;color:var(--muted2);line-height:1.5;}
.tool-info p strong{color:var(--cyan);}

/* ── FAQ */
.faq-list{display:flex;flex-direction:column;gap:2px;margin-top:40px;}
.faq-item{
  background:var(--glass);border:1px solid rgba(0,229,255,.07);
  overflow:hidden;
}
.faq-q{
  display:flex;align-items:center;justify-content:space-between;gap:20px;
  padding:22px 28px;cursor:pointer;
  transition:background .2s;
}
.faq-q:hover{background:rgba(0,229,255,.025);}
.faq-q-text{
  font-family:var(--fdisplay);font-size:11px;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;color:var(--white);
}
.faq-toggle{
  width:24px;height:24px;flex-shrink:0;
  border:1px solid rgba(0,229,255,.2);color:var(--cyan);
  display:flex;align-items:center;justify-content:center;
  font-size:14px;transition:transform .3s,background .2s;
}
.faq-item.open .faq-toggle{transform:rotate(45deg);background:rgba(0,229,255,.08);}
.faq-a{
  display:none;padding:0 28px 22px;
  font-size:13px;line-height:1.8;color:var(--muted2);
  border-top:1px solid rgba(0,229,255,.05);padding-top:18px;
}
.faq-item.open .faq-a{display:block;}
.faq-a strong{color:var(--white);}
.faq-a em{color:var(--cyan);font-style:normal;}

/* ── FINAL CTA */
.final{
  text-align:center;padding:120px 40px;
  background:radial-gradient(ellipse 800px 400px at center,rgba(0,229,255,.06) 0%,transparent 70%);
  border-top:1px solid rgba(0,229,255,.07);
}
.final h2{
