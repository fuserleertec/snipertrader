<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TraderEdge Command Portal — SniperTrader</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Space+Mono:wght@400;700&family=Syne:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --obs:#020408;--obs2:#06090F;--obs3:#0A1018;--obs4:#111820;--obs5:#1A2230;
  --cyan:#00D4FF;--cyan2:#00A8CC;--cyan-dim:rgba(0,212,255,0.10);
  --gold:#F0C040;--gold2:#C9A84C;--gold-dim:rgba(240,192,64,0.10);
  --red:#FF4455;--red-dim:rgba(255,68,85,0.09);
  --green:#00FF88;--green-dim:rgba(0,255,136,0.08);
  --amber:#FF9F43;--amber-dim:rgba(255,159,67,0.09);
  --text:#FFFFFF;--text2:#E8F2FA;--text3:#A8C4D8;--text4:#5A7888;
  --border:rgba(0,212,255,0.13);--border2:rgba(0,212,255,0.26);
  --gold-border:rgba(240,192,64,0.18);
}
/* ─── LIGHT MODE ─── */
body.light-mode{
  --obs:#F0F4F8;--obs2:#E4ECF4;--obs3:#FFFFFF;--obs4:#EAF0F8;--obs5:#D8E4F0;
  --text:#0A1828;--text2:#1E3048;--text3:#3A5878;--text4:#6A88A8;
  --border:rgba(0,150,200,0.18);--border2:rgba(0,150,200,0.36);
  --cyan:#0080B8;--cyan2:#006090;--cyan-dim:rgba(0,128,184,0.10);
  --gold:#B07800;--gold2:#9A6A00;--gold-dim:rgba(176,120,0,0.10);
  --gold-border:rgba(176,120,0,0.22);
  --green:#007A40;--green-dim:rgba(0,122,64,0.09);
  --red:#CC2233;--red-dim:rgba(204,34,51,0.09);
  --amber:#C07020;--amber-dim:rgba(192,112,32,0.09);
}
body.light-mode::before{opacity:.15;}
body.light-mode #pc{opacity:.25;}

/* ─── LIGHT MODE: override all hardcoded #fff / white text ─── */
body.light-mode .login-title,
body.light-mode .lf-input,
body.light-mode .tfa-input,
body.light-mode .aub-name,
body.light-mode .sidebar-link:hover,
body.light-mode .gph-title,
body.light-mode .form-input,
body.light-mode .form-select,
body.light-mode .tl-title,
body.light-mode .mp-name,
body.light-mode .dl-card-name,
body.light-mode .toggle-name,
body.light-mode .app-strip-title,
body.light-mode .app-dl-btn.ios,
body.light-mode .app-dl-btn.android{color:var(--text);}

body.light-mode .lf-input,
body.light-mode .tfa-input,
body.light-mode .form-input,
body.light-mode .form-select{background:var(--obs3);color:var(--text);}
body.light-mode .lf-input::placeholder{color:var(--text4);}

body.light-mode .app-dl-btn.ios{background:rgba(0,0,0,.06);border-color:rgba(0,0,0,.15);}

/* Inline color:#fff overrides via CSS variable trick */
body.light-mode [style*="color:#fff"],
body.light-mode [style*='color:#fff']{color:var(--text) !important;-webkit-text-fill-color:initial !important;}

/* Section headings with inline color:#fff */
body.light-mode [style*="font-weight:900"][style*="color:#fff"],
body.light-mode [style*="font-weight:700"][style*="color:#fff"]{color:var(--text) !important;}

/* Billing price */
body.light-mode [style*="font-size:16px"][style*="color:#fff"]{color:var(--text) !important;}
html{scroll-behavior:smooth;}
body{background:var(--obs);color:var(--text);font-family:'Syne',sans-serif;overflow-x:hidden;cursor:none;min-height:100vh;transition:background .3s,color .3s;}
body.light-mode{background:var(--obs);}
/* THEME TOGGLE BUTTON */
#themeToggle{background:var(--obs4);border:1px solid var(--border);border-radius:20px;padding:6px 12px;font-family:'Orbitron',monospace;font-size:8px;font-weight:700;color:var(--text3);cursor:none;letter-spacing:1px;transition:all .2s;display:flex;align-items:center;gap:6px;}
#themeToggle:hover{border-color:var(--cyan);color:var(--cyan);}
#themeToggle .toggle-icon{font-size:14px;}

/* CURSOR */
#cur{position:fixed;width:10px;height:10px;background:var(--cyan);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:screen;transition:background .15s,transform .1s;}
#cur-ring{position:fixed;width:34px;height:34px;border:1px solid rgba(0,212,255,.45);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .2s,height .2s;}
body:has(button:hover,a:hover,input:hover) #cur{background:var(--gold);transform:translate(-50%,-50%) scale(1.5);}
body:has(button:hover,a:hover) #cur-ring{width:50px;height:50px;border-color:rgba(240,192,64,.35);}

#pc{position:fixed;inset:0;pointer-events:none;z-index:0;}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");pointer-events:none;z-index:1;opacity:.45;}

/* ─── LOGIN SCREEN ─── */
#loginScreen{position:fixed;inset:0;z-index:500;display:flex;align-items:center;justify-content:center;background:var(--obs);}
.login-orb1{position:absolute;width:700px;height:700px;background:radial-gradient(circle,rgba(0,212,255,.07) 0%,transparent 65%);top:-200px;left:-150px;pointer-events:none;animation:od1 16s ease-in-out infinite;}
.login-orb2{position:absolute;width:500px;height:500px;background:radial-gradient(circle,rgba(240,192,64,.05) 0%,transparent 65%);bottom:-100px;right:-80px;pointer-events:none;animation:od2 20s ease-in-out infinite;}
@keyframes od1{0%,100%{transform:translate(0,0);}50%{transform:translate(30px,-25px);}}
@keyframes od2{0%,100%{transform:translate(0,0);}50%{transform:translate(-25px,35px);}}
.login-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(0,212,255,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,.02) 1px,transparent 1px);background-size:58px 58px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 20%,transparent 100%);}

.login-wrap{position:relative;z-index:2;width:100%;max-width:440px;padding:20px;}
.login-logo-wrap{text-align:center;margin-bottom:32px;}
.login-logo{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;letter-spacing:3px;color:var(--cyan);}
.login-logo span{color:var(--gold);}
.login-logo-sub{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:3px;color:var(--text3);text-transform:uppercase;margin-top:6px;}

.login-card{background:linear-gradient(145deg,#0A1220,#06090F);border:1px solid var(--border2);border-radius:20px;padding:36px;box-shadow:0 0 60px rgba(0,212,255,.08),0 30px 60px rgba(0,0,0,.7),inset 0 1px 0 rgba(255,255,255,.04);position:relative;overflow:hidden;}
.login-card::after{content:'';position:absolute;inset:0;background:conic-gradient(transparent 0deg,rgba(0,212,255,.015) 90deg,transparent 180deg);animation:cspin 12s linear infinite;pointer-events:none;}
@keyframes cspin{to{transform:rotate(360deg);}}

.login-title{font-family:'Orbitron',monospace;font-size:18px;font-weight:700;color:#fff;margin-bottom:6px;}
.login-sub{font-size:12px;color:var(--text3);font-family:'Space Mono',monospace;margin-bottom:28px;line-height:1.5;}

.login-field{margin-bottom:18px;}
.lf-label{font-family:'Orbitron',monospace;font-size:8.5px;color:var(--cyan);letter-spacing:2px;text-transform:uppercase;display:block;margin-bottom:8px;}
.lf-input-wrap{position:relative;}
.lf-input{width:100%;background:var(--obs4);border:1px solid var(--border);border-radius:8px;padding:13px 16px;color:#fff;font-family:'Syne',sans-serif;font-size:13px;outline:none;transition:border-color .2s;}
.lf-input:focus{border-color:var(--cyan);}
.lf-input::placeholder{color:var(--text4);}
.lf-icon{position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:16px;pointer-events:none;opacity:.4;}

.login-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;}
.login-remember{display:flex;align-items:center;gap:8px;font-family:'Space Mono',monospace;font-size:10px;color:var(--text3);cursor:none;}
.login-checkbox{width:16px;height:16px;border-radius:3px;border:1.5px solid var(--text4);background:transparent;appearance:none;cursor:none;transition:all .2s;}
.login-checkbox:checked{background:var(--cyan);border-color:var(--cyan);}
.login-forgot{font-family:'Space Mono',monospace;font-size:10px;color:var(--cyan);text-decoration:none;letter-spacing:.5px;}

.login-btn{width:100%;background:linear-gradient(90deg,var(--cyan),var(--cyan2));color:#000;border:none;border-radius:10px;padding:15px 24px;font-family:'Orbitron',monospace;font-size:11px;font-weight:700;letter-spacing:2px;cursor:none;transition:all .3s;text-transform:uppercase;box-shadow:0 0 24px rgba(0,212,255,.25);margin-bottom:16px;}
.login-btn:hover{box-shadow:0 0 40px rgba(0,212,255,.35);transform:translateY(-1px);}

.login-divider{display:flex;align-items:center;gap:12px;margin-bottom:16px;}
.login-divider-line{flex:1;height:1px;background:var(--border);}
.login-divider-txt{font-family:'Space Mono',monospace;font-size:9px;color:var(--text4);letter-spacing:1px;}

.login-biometric{display:flex;gap:10px;}
.lbio-btn{flex:1;background:var(--obs4);border:1px solid var(--border);border-radius:8px;padding:12px;font-family:'Space Mono',monospace;font-size:10px;color:var(--text3);cursor:none;transition:all .2s;text-align:center;display:flex;flex-direction:column;align-items:center;gap:5px;}
.lbio-btn:hover{border-color:var(--cyan);color:var(--cyan);}
.lbio-icon{font-size:20px;}

.login-error{background:var(--red-dim);border:1px solid rgba(255,68,85,.3);border-radius:6px;padding:10px 14px;font-family:'Space Mono',monospace;font-size:10px;color:#FF8899;margin-bottom:14px;display:none;}
.login-error.show{display:block;}

.login-2fa{display:none;margin-bottom:18px;}
.login-2fa.show{display:block;}
.tfa-label{font-family:'Orbitron',monospace;font-size:8.5px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;display:block;margin-bottom:8px;}
.tfa-inputs{display:flex;gap:8px;}
.tfa-input{flex:1;background:var(--obs4);border:1px solid var(--border);border-radius:8px;padding:12px 0;color:#fff;font-family:'Orbitron',monospace;font-size:18px;font-weight:700;text-align:center;outline:none;transition:border-color .2s;}
.tfa-input:focus{border-color:var(--gold);}

/* ─── ADMIN DASHBOARD ─── */
#adminDash{display:none;position:relative;z-index:2;min-height:100vh;}

/* TOP NAV */
.admin-nav{position:fixed;top:0;left:0;right:0;z-index:200;padding:14px 32px;display:flex;align-items:center;justify-content:space-between;background:rgba(2,4,8,.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
.admin-nav-logo{font-family:'Orbitron',monospace;font-size:12px;font-weight:900;letter-spacing:3px;color:var(--cyan);text-decoration:none;}
.admin-nav-logo span{color:var(--gold);}
.admin-nav-label{font-family:'Space Mono',monospace;font-size:8px;color:var(--text4);letter-spacing:2px;text-transform:uppercase;margin-left:8px;}
.admin-nav-right{display:flex;align-items:center;gap:16px;}
.admin-user-badge{display:flex;align-items:center;gap:8px;background:var(--obs3);border:1px solid var(--border);border-radius:20px;padding:6px 14px;}
.aub-avatar{width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--gold));display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-size:9px;font-weight:700;color:#000;}
.aub-name{font-family:'Space Mono',monospace;font-size:10px;color:#fff;}
.aub-role{font-size:8px;color:var(--cyan);font-family:'Orbitron',monospace;letter-spacing:1px;}
.admin-logout-btn{background:var(--red-dim);border:1px solid rgba(255,68,85,.25);border-radius:6px;padding:7px 14px;font-family:'Orbitron',monospace;font-size:8.5px;font-weight:700;color:#FF8899;cursor:none;letter-spacing:1px;transition:all .2s;}
.admin-logout-btn:hover{background:var(--red);color:#fff;border-color:var(--red);}

/* SIDEBAR */
.admin-layout{display:flex;padding-top:57px;min-height:100vh;}
.admin-sidebar{width:240px;background:var(--obs2);border-right:1px solid var(--border);padding:24px 0;position:fixed;top:57px;bottom:0;left:0;overflow-y:auto;z-index:100;}
.sidebar-section-label{font-family:'Orbitron',monospace;font-size:8px;color:var(--text4);letter-spacing:2.5px;text-transform:uppercase;padding:0 20px;margin-bottom:8px;margin-top:20px;}
.sidebar-section-label:first-child{margin-top:0;}
.sidebar-link{display:flex;align-items:center;gap:12px;padding:11px 20px;font-family:'Space Mono',monospace;font-size:10px;color:var(--text3);text-decoration:none;letter-spacing:.5px;transition:all .2s;cursor:none;position:relative;}
.sidebar-link:hover{background:var(--obs3);color:#fff;}
.sidebar-link.active{background:var(--cyan-dim);color:var(--cyan);border-right:2px solid var(--cyan);}
.sidebar-link-icon{font-size:14px;width:18px;text-align:center;flex-shrink:0;}
.sidebar-badge{margin-left:auto;font-family:'Orbitron',monospace;font-size:8px;font-weight:700;padding:2px 7px;border-radius:10px;}
.sidebar-badge.red{background:var(--red-dim);border:1px solid rgba(255,68,85,.25);color:var(--red);}
.sidebar-badge.green{background:var(--green-dim);border:1px solid rgba(0,255,136,.2);color:var(--green);}
.sidebar-badge.gold{background:var(--gold-dim);border:1px solid rgba(240,192,64,.2);color:var(--gold);}

/* MAIN CONTENT */
.admin-main{flex:1;margin-left:240px;padding:32px;min-height:calc(100vh - 57px);}

/* DASHBOARD PANELS */
.dash-panel{display:none;}
.dash-panel.active{display:block;}

/* STATS ROW */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px;}
.stat-card{background:var(--obs3);border:1px solid var(--border);border-radius:14px;padding:20px;position:relative;overflow:hidden;transition:border-color .3s;}
.stat-card:hover{border-color:var(--border2);}
.stat-card::after{content:'';position:absolute;inset:0;background:conic-gradient(transparent 0deg,rgba(0,212,255,.012) 90deg,transparent 180deg);animation:cspin 12s linear infinite;pointer-events:none;}
.sc-val{font-family:'Orbitron',monospace;font-size:28px;font-weight:900;display:block;margin-bottom:4px;}
.sc-label{font-size:10px;color:var(--text3);font-family:'Space Mono',monospace;letter-spacing:.5px;text-transform:uppercase;display:block;}
.sc-change{font-size:9px;font-family:'Space Mono',monospace;margin-top:5px;display:block;}
.sc-change.up{color:var(--green);}
.sc-change.dn{color:var(--red);}
.sc-change.nt{color:var(--gold);}

/* GLASS PANELS */
.g-panel{background:var(--obs3);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:20px;}
.g-panel-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px;}
.gph-left{display:flex;align-items:center;gap:12px;}
.gph-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.gph-icon.c{background:var(--cyan-dim);border:1px solid rgba(0,212,255,.2);}
.gph-icon.g{background:var(--gold-dim);border:1px solid rgba(240,192,64,.2);}
.gph-icon.r{background:var(--red-dim);border:1px solid rgba(255,68,85,.2);}
.gph-icon.gr{background:var(--green-dim);border:1px solid rgba(0,255,136,.15);}
.gph-icon.a{background:var(--amber-dim);border:1px solid rgba(255,159,67,.2);}
.gph-title{font-family:'Orbitron',monospace;font-size:12px;font-weight:700;color:#fff;}
.gph-sub{font-size:10px;color:var(--text3);font-family:'Space Mono',monospace;margin-top:2px;}

/* TABLES */
.admin-table{width:100%;border-collapse:collapse;}
.admin-table th{font-family:'Orbitron',monospace;font-size:8px;letter-spacing:2px;color:var(--text4);text-transform:uppercase;text-align:left;padding:10px 14px;border-bottom:1px solid var(--border);}
.admin-table td{padding:13px 14px;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px;color:var(--text2);vertical-align:middle;}
.admin-table tr:hover td{background:rgba(0,212,255,.02);}
.admin-table tr:last-child td{border-bottom:none;}

/* BADGES */
.badge{font-family:'Orbitron',monospace;font-size:8px;font-weight:700;letter-spacing:1px;padding:3px 10px;border-radius:20px;text-transform:uppercase;}
.badge.active{background:var(--green-dim);border:1px solid rgba(0,255,136,.2);color:var(--green);}
.badge.inactive{background:var(--red-dim);border:1px solid rgba(255,68,85,.2);color:#FF8899;}
.badge.trial{background:var(--gold-dim);border:1px solid rgba(240,192,64,.2);color:var(--gold);}
.badge.pro{background:var(--cyan-dim);border:1px solid rgba(0,212,255,.2);color:var(--cyan);}
.badge.elite{background:linear-gradient(90deg,rgba(240,192,64,.15),rgba(0,212,255,.1));border:1px solid rgba(240,192,64,.3);color:var(--gold);}

/* ACTION BUTTONS */
.action-btn{font-family:'Orbitron',monospace;font-size:8px;font-weight:700;letter-spacing:1px;padding:5px 12px;border-radius:5px;cursor:none;text-transform:uppercase;transition:all .2s;border:none;}
.action-btn.cyan{background:var(--cyan-dim);border:1px solid rgba(0,212,255,.25);color:var(--cyan);}
.action-btn.cyan:hover{background:var(--cyan);color:#000;}
.action-btn.red{background:var(--red-dim);border:1px solid rgba(255,68,85,.22);color:#FF8899;}
.action-btn.red:hover{background:var(--red);color:#fff;}
.action-btn.gold{background:var(--gold-dim);border:1px solid rgba(240,192,64,.22);color:var(--gold);}
.action-btn.gold:hover{background:var(--gold);color:#000;}
.action-btn.green{background:var(--green-dim);border:1px solid rgba(0,255,136,.18);color:var(--green);}

/* FORM FIELDS */
.form-field{margin-bottom:16px;}
.form-label{font-family:'Orbitron',monospace;font-size:8.5px;color:var(--cyan);letter-spacing:2px;text-transform:uppercase;display:block;margin-bottom:7px;}
.form-input{width:100%;background:var(--obs4);border:1px solid var(--border);border-radius:8px;padding:11px 14px;color:#fff;font-family:'Syne',sans-serif;font-size:13px;outline:none;transition:border-color .2s;}
.form-input:focus{border-color:var(--cyan);}
.form-input::placeholder{color:var(--text4);}
.form-select{width:100%;background:var(--obs4);border:1px solid var(--border);border-radius:8px;padding:11px 14px;color:#fff;font-family:'Syne',sans-serif;font-size:13px;outline:none;appearance:none;cursor:none;}
.form-select:focus{border-color:var(--cyan);}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.save-btn{background:linear-gradient(90deg,var(--cyan),var(--cyan2));color:#000;border:none;border-radius:8px;padding:12px 24px;font-family:'Orbitron',monospace;font-size:10px;font-weight:700;letter-spacing:1.5px;cursor:none;transition:all .2s;text-transform:uppercase;}
.save-btn:hover{box-shadow:0 0 20px rgba(0,212,255,.3);transform:translateY(-1px);}

/* PRODUCT KEY DISPLAY */
.key-display{background:var(--obs4);border:1px solid var(--border2);border-radius:10px;padding:16px 20px;font-family:'Orbitron',monospace;font-size:15px;font-weight:700;color:var(--gold);letter-spacing:3px;display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.key-copy-btn{background:var(--gold-dim);border:1px solid var(--gold-border);border-radius:6px;padding:6px 14px;font-family:'Orbitron',monospace;font-size:8px;color:var(--gold);cursor:none;transition:all .2s;font-weight:700;letter-spacing:1px;}
.key-copy-btn:hover{background:var(--gold);color:#000;}

/* TIMELINE */
.timeline{display:flex;flex-direction:column;gap:0;}
.tl-item{display:flex;gap:16px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.tl-item:last-child{border-bottom:none;}
.tl-dot-wrap{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:16px;}
.tl-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.tl-line{flex:1;width:1px;background:var(--border);margin-top:4px;}
.tl-content{flex:1;min-width:0;}
.tl-title{font-size:12px;color:#fff;margin-bottom:3px;}
.tl-meta{font-size:10px;color:var(--text3);font-family:'Space Mono',monospace;}

/* MODULE PROGRESS */
.module-progress-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
.mp-card{background:var(--obs4);border:1px solid var(--border);border-radius:10px;padding:14px;}
.mp-card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.mp-name{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;color:#fff;}
.mp-pct{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;}
.mp-bar-track{height:4px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden;}
.mp-bar-fill{height:100%;border-radius:2px;}
