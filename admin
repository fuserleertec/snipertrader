<script>
// CURSOR
const cur=document.getElementById('cur'),ring=document.getElementById('cur-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function ar(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(ar);})();

// PARTICLES
const pc=document.getElementById('pc'),ctx=pc.getContext('2d');
pc.width=window.innerWidth;pc.height=window.innerHeight;
window.addEventListener('resize',()=>{pc.width=window.innerWidth;pc.height=window.innerHeight;});
const pts=[];
const pCols=['0,212,255','240,192,64','0,255,136'];
for(let i=0;i<80;i++) pts.push({x:Math.random()*pc.width,y:Math.random()*pc.height,vx:(Math.random()-.5)*.2,vy:(Math.random()-.5)*.2,r:Math.random()*1.3+.3,a:Math.random()*.22+.06,col:pCols[Math.floor(Math.random()*pCols.length)]});
let pmx=pc.width/2,pmy=pc.height/2;
document.addEventListener('mousemove',e=>{pmx=e.clientX;pmy=e.clientY;});
(function dp(){
  ctx.clearRect(0,0,pc.width,pc.height);
  for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
    const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
    if(d<120){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.strokeStyle=`rgba(0,212,255,${(1-d/120)*.045})`;ctx.lineWidth=.5;ctx.stroke();}
  }
  pts.forEach(p=>{
    const dx=pmx-p.x,dy=pmy-p.y,d=Math.sqrt(dx*dx+dy*dy);
    if(d<180){p.vx+=dx/d*.006;p.vy+=dy/d*.006;}
    p.vx*=.99;p.vy*=.99;p.x+=p.vx;p.y+=p.vy;
    if(p.x<0)p.x=pc.width;if(p.x>pc.width)p.x=0;
    if(p.y<0)p.y=pc.height;if(p.y>pc.height)p.y=0;
    ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=`rgba(${p.col},${p.a})`;ctx.fill();
  });
  requestAnimationFrame(dp);
})();

// SCROLL OBSERVER
const so=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('v');}),{threshold:.06});
