.dl-card-icon{font-size:28px;margin-bottom:10px;display:block;}
.dl-card-name{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;color:#fff;margin-bottom:4px;}
.dl-card-meta{font-size:10px;color:var(--text3);font-family:'Space Mono',monospace;margin-bottom:12px;line-height:1.5;}
.dl-card-btn{display:flex;align-items:center;gap:6px;font-family:'Orbitron',monospace;font-size:9px;font-weight:700;color:var(--cyan);letter-spacing:1px;text-transform:uppercase;cursor:none;}

/* TOGGLE SWITCH */
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.04);}
.toggle-row:last-child{border-bottom:none;}
.toggle-info{}
.toggle-name{font-size:12px;color:#fff;margin-bottom:2px;}
.toggle-desc{font-size:10px;color:var(--text3);font-family:'Space Mono',monospace;}
.toggle-switch{position:relative;width:44px;height:24px;flex-shrink:0;}
.toggle-switch input{opacity:0;width:0;height:0;position:absolute;}
.toggle-slider{position:absolute;inset:0;background:var(--obs4);border:1px solid var(--border);border-radius:12px;cursor:none;transition:all .3s;}
.toggle-slider::before{content:'';position:absolute;width:18px;height:18px;left:2px;top:50%;transform:translateY(-50%);background:var(--text4);border-radius:50%;transition:all .3s;}
.toggle-switch input:checked + .toggle-slider{background:var(--cyan-dim);border-color:var(--cyan);}
.toggle-switch input:checked + .toggle-slider::before{background:var(--cyan);transform:translateY(-50%) translateX(20px);}

/* CHART BARS */
.mini-bar-chart{display:flex;align-items:flex-end;gap:4px;height:60px;padding-top:8px;}
.mbc-bar{flex:1;border-radius:3px 3px 0 0;background:var(--cyan-dim);border:1px solid rgba(0,212,255,.2);transition:height .5s ease;min-width:0;}
.mbc-bar.active{background:var(--cyan-dim);border-color:var(--cyan);}

/* ALERT ROW */
.alert-item{display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--obs4);border:1px solid var(--border);border-radius:8px;margin-bottom:8px;}
.ai-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
