// THEME TOGGLE
function toggleTheme(){
  const body=document.body;
  const isLight=body.classList.toggle('light-mode');
  // Nav button
  const icon=document.querySelector('#themeToggle .toggle-icon');
  const label=document.getElementById('themeLabel');
  // Login button
  const iconL=document.getElementById('themeIconLogin');
  const labelL=document.getElementById('themeLabelLogin');
  if(isLight){
    if(icon)icon.textContent='☀';if(label)label.textContent='LIGHT';
    if(iconL)iconL.textContent='☀';if(labelL)labelL.textContent='LIGHT MODE';
    patchInlineColors(true);
  } else {
    if(icon)icon.textContent='🌙';if(label)label.textContent='DARK';
    if(iconL)iconL.textContent='🌙';if(labelL)labelL.textContent='DARK MODE';
    patchInlineColors(false);
  }
  localStorage.setItem('theme',isLight?'light':'dark');
}

function patchInlineColors(isLight){
  // Walk all elements with inline style containing color:#fff or similar whites
  const all=document.querySelectorAll('[style]');
  all.forEach(el=>{
    if(isLight){
      const s=el.getAttribute('style')||'';
      if(/color\s*:\s*#fff/i.test(s)||/color\s*:\s*#ffffff/i.test(s)||/color\s*:\s*white/i.test(s)){
        el.dataset.origColor=s;
        // Replace the white color with dark text
        el.style.color='#0A1828';
        // Also clear webkit-text-fill-color if set to transparent (gradient text should stay)
        if(!/webkit-text-fill-color\s*:\s*transparent/.test(s)){
          el.style.webkitTextFillColor='#0A1828';
        }
      }
    } else {
      // Restore original inline styles
      if(el.dataset.origColor!==undefined){
        el.setAttribute('style',el.dataset.origColor);
        delete el.dataset.origColor;
      }
    }
  });
}

// Restore theme on load
(function(){
  if(localStorage.getItem('theme')==='light'){
    document.body.classList.add('light-mode');
    const icon=document.querySelector('#themeToggle .toggle-icon');
    const label=document.getElementById('themeLabel');
    const iconL=document.getElementById('themeIconLogin');
    const labelL=document.getElementById('themeLabelLogin');
    if(icon)icon.textContent='☀';if(label)label.textContent='LIGHT';
    if(iconL)iconL.textContent='☀';if(labelL)labelL.textContent='LIGHT MODE';
    // Patch after DOM ready
    setTimeout(()=>patchInlineColors(true),50);
  }
})();
