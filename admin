function bioLogin(){doLogin(true);}

let loginAttempts=0;
function doLogin(skip=false){
  const btn=document.getElementById('loginBtn');
  const btnTxt=document.getElementById('loginBtnText');
  const email=document.getElementById('loginEmail').value;
  const pass=document.getElementById('loginPass').value;
  const err=document.getElementById('loginError');

  if(!skip && !email){err.textContent='⚠ Please enter your email address.';err.classList.add('show');return;}

  btnTxt.innerHTML='<span class="spin">◌</span> AUTHENTICATING...';
  btn.style.opacity='.7';
  err.classList.remove('show');

  setTimeout(()=>{
    // Demo: any credentials work, or show 2FA step
    if(pass==='wrong'){
      loginAttempts++;
      err.textContent='⚠ Invalid credentials. '+(3-loginAttempts)+' attempts remaining.';
      err.classList.add('show');
      btnTxt.innerHTML='⬡ SIGN IN TO COMMAND PORTAL';
      btn.style.opacity='1';
    } else if(!skip && pass.length>0 && loginAttempts===0 && !document.getElementById('twoFAField').classList.contains('show')){
      // Show 2FA
      document.getElementById('twoFAField').classList.add('show');
      btnTxt.innerHTML='⬡ VERIFY 2FA CODE';
      btn.style.opacity='1';
      document.getElementById('t1').focus();
    } else {
      // Login success
      loginSuccess(email||'Jaylu');
    }
  },1200);
}

function loginSuccess(email){
  const screen=document.getElementById('loginScreen');
  const dash=document.getElementById('adminDash');
  // Set name
  const name=email.includes('@')?email.split('@')[0].charAt(0).toUpperCase()+email.split('@')[0].slice(1):'Jaylu';
  const initials=name.substring(0,2).toUpperCase();
  document.getElementById('navName').textContent=name;
  document.getElementById('navAvatar').textContent=initials;
  // Animate out login
  screen.style.transition='opacity .6s ease, transform .6s ease';
  screen.style.opacity='0';
  screen.style.transform='scale(0.97)';
  setTimeout(()=>{
    screen.style.display='none';
    dash.style.display='block';
    // Apply light mode patch on inline styles now that dash is visible
    if(document.body.classList.contains('light-mode')) patchInlineColors(true);
    // Trigger scroll observers
    setTimeout(()=>{document.querySelectorAll('.fu').forEach(el=>so.observe(el));},100);
  },600);
}

function doLogout(){
  const dash=document.getElementById('adminDash');
  const screen=document.getElementById('loginScreen');
  dash.style.transition='opacity .4s';
  dash.style.opacity='0';
  setTimeout(()=>{
