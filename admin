.app-strip-sub{font-size:12px;color:var(--text3);}
.app-strip-btns{display:flex;gap:10px;}
.app-dl-btn{display:flex;align-items:center;gap:10px;padding:10px 18px;border-radius:8px;text-decoration:none;transition:all .2s;}
.app-dl-btn.ios{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.15);color:#fff;}
.app-dl-btn.ios:hover{background:rgba(255,255,255,.1);transform:translateY(-1px);}
.app-dl-btn.android{background:var(--cyan-dim);border:1px solid var(--border2);color:#fff;}
.app-dl-btn.android:hover{background:rgba(0,212,255,.15);border-color:var(--cyan);transform:translateY(-1px);}
.adl-icon{font-size:22px;line-height:1;}
.adl-text{text-align:left;}
.adl-label{display:block;font-size:9px;color:var(--text3);font-family:'Space Mono',monospace;letter-spacing:.5px;}
.adl-name{display:block;font-family:'Orbitron',monospace;font-size:12px;font-weight:700;margin-top:1px;}

/* PULSE */
.pulse{width:7px;height:7px;border-radius:50%;display:inline-block;animation:pls 2s infinite;}
@keyframes pls{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.4;transform:scale(.8);}}
.spin{display:inline-block;animation:spn .7s linear infinite;}
@keyframes spn{to{transform:rotate(360deg);}}
.fu{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease;}
.fu.v{opacity:1;transform:translateY(0);}
.d1{transition-delay:.1s;}.d2{transition-delay:.2s;}.d3{transition-delay:.3s;}

/* ─── SITE FOOTER ─── */
