<script>
// theme toggle
const toggleBtn = document.getElementById('themeToggleBtn');
const body = document.body;
function setTheme(theme) {
  if(theme === 'light') {
    body.classList.add('light-mode');
    toggleBtn.innerHTML = '☀️';
    localStorage.setItem('usmeTheme', 'light');
  } else {
    body.classList.remove('light-mode');
    toggleBtn.innerHTML = '🌙';
    localStorage.setItem('usmeTheme', 'dark');
  }
}
const savedTheme = localStorage.getItem('usmeTheme');
if(savedTheme === 'light') setTheme('light');
else setTheme('dark');
toggleBtn.addEventListener('click', () => {
  if(body.classList.contains('light-mode')) setTheme('dark');
  else setTheme('light');
});
// reveal & score bar
const revEls = document.querySelectorAll('.reveal');
const io = new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target)}})},{threshold:0.12});
revEls.forEach(el=>io.observe(el));
const sbFill = document.getElementById('scoreDemoFill');
if(sbFill){ const obs = new IntersectionObserver(e=>{if(e[0].isIntersecting){sbFill.style.width='86%';obs.disconnect()}},{threshold:.3}); obs.observe(sbFill.closest('.sotd-wrap')) }
document.querySelectorAll('.faq-item').forEach(item=>{item.querySelector('.faq-q')?.addEventListener('click',()=>{const open=item.classList.contains('open');document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));if(!open) item.classList.add('open');})});
document.querySelectorAll('a[href^="#"]').forEach(anchor=>{anchor.addEventListener('click',function(e){const target=document.querySelector(this.getAttribute('href'));if(target){e.preventDefault();target.scrollIntoView({behavior:'smooth',block:'start'})}})});
