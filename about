<script>
  // Cursor, particles, tilt, reveal (identical robust functionality)
  const dot = document.getElementById('cursor-dot'), ring = document.getElementById('cursor-ring');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{ mx=e.clientX; my=e.clientY; });
  function animateCursor(){ dot.style.transform=`translate(${mx-3}px,${my-3}px)`; rx+=(mx-rx)*0.12; ry+=(my-ry)*0.12; ring.style.transform=`translate(${rx-18}px,${ry-18}px)`; requestAnimationFrame(animateCursor); } animateCursor();
  const canvas = document.getElementById('particles'), ctx = canvas.getContext('2d'); let W,H,particles=[];
  function resizeCanvas(){ W=canvas.width=window.innerWidth; H=canvas.height=window.innerHeight; } resizeCanvas(); window.addEventListener('resize',resizeCanvas);
  class Particle { constructor(){ this.reset(); } reset(){ this.x=Math.random()*W; this.y=Math.random()*H; this.size=Math.random()*1.5+0.3; this.sx=(Math.random()-0.5)*0.3; this.sy=(Math.random()-0.5)*0.3; this.op=Math.random()*0.5+0.1; this.color=Math.random()>0.7?'#f0c040':'#00d4ff'; this.pulse=Math.random()*Math.PI*2; } update(){ this.x+=this.sx; this.y+=this.sy; this.pulse+=0.02; if(this.x<0||this.x>W||this.y<0||this.y>H) this.reset(); } draw(){ ctx.save(); ctx.globalAlpha=this.op*(0.7+0.3*Math.sin(this.pulse)); ctx.fillStyle=this.color; ctx.shadowBlur=6; ctx.shadowColor=this.color; ctx.beginPath(); ctx.arc(this.x,this.y,this.size,0,Math.PI*2); ctx.fill(); ctx.restore(); } }
  for(let i=0;i<100;i++) particles.push(new Particle());
  function drawParticles(){ ctx.clearRect(0,0,W,H); for(let p of particles){ p.update(); p.draw(); } requestAnimationFrame(drawParticles); } drawParticles();
  function initTilt(el,intensity=12){ if(!el) return; el.addEventListener('mousemove',e=>{ const r=el.getBoundingClientRect(); const cx=r.left+r.width/2, cy=r.top+r.height/2; const rx=((e.clientY-cy)/(r.height/2))*-intensity; const ry=((e.clientX-cx)/(r.width/2))*intensity; el.style.transform=`perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg)`; el.style.boxShadow=`${-ry*1.5}px ${rx*1.5}px 40px rgba(0,0,0,0.5), 0 0 40px rgba(0,212,255,0.12)`; }); el.addEventListener('mouseleave',()=>{ el.style.transform='perspective(800px) rotateX(0) rotateY(0)'; el.style.boxShadow=''; }); }
  initTilt(document.getElementById('origin-tilt'),8); initTilt(document.getElementById('philo-tilt-1'),6); initTilt(document.getElementById('philo-tilt-2'),6); document.querySelectorAll('[data-tilt]').forEach(el=>initTilt(el,6));
  const observer = new IntersectionObserver(entries=>{ entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('visible'); observer.unobserve(e.target); } }); },{threshold:0.1}); document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));
  document.addEventListener('mousemove',e=>{ const dx=(e.clientX-window.innerWidth/2)/(window.innerWidth/2); const dy=(e.clientY-window.innerHeight/2)/(window.innerHeight/2); document.querySelectorAll('.hero-glow-orb').forEach(el=>el.style.transform=`translate(calc(-50% + ${dx*30}px), calc(-50% + ${dy*20}px))`); document.querySelectorAll('.cta-glow').forEach(el=>el.style.transform=`translate(calc(-50% + ${dx*20}px), calc(-50% + ${dy*15}px))`); });
</script>
