                  </div>
                  <button
                    onClick={() => setActiveTab("simulator")}
                    className="flex items-center gap-1 text-xs font-semibold bg-slate-900 hover:bg-slate-800 text-white px-3.5 py-2 rounded-lg shadow-sm transition-colors whitespace-nowrap"
