              </div>
            </motion.div>
          )}

          {/* TAB 4: CHALLENGE SIMULATOR */}
          {activeTab === "simulator" && (
            <motion.div
              key="simulator-tab"
              initial={{ opacity: 0, y: 15 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -15 }}
              transition={{ duration: 0.25 }}
              className="space-y-6"
            >
              
              {/* Header Status Bar */}
              <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
                
                {/* Account balance */}
